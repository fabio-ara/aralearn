{
  "contract": "aralearn.intent.v1",
  "courses": [
    {
      "title": "Curso renderizável",
      "modules": [
        {
          "title": "Módulo inicial",
          "lessons": [
            {
              "title": "Lição demonstrativa",
              "microsequences": [
                {
                  "title": "Microssequência demonstrativa",
                  "objective": "Exibir intenções básicas do renderizador",
                  "cards": [
                    {
                      "title": "Texto inicial",
                      "intent": "text",
                      "data": {
                        "text": "Texto de exemplo para renderização."
                      }
                    },
                    {
                      "title": "Pergunta guiada",
                      "intent": "ask",
                      "data": {
                        "prompt": "Qual parte do contrato agrupa cards?",
                        "options": [
                          "Microssequência",
                          "Módulo",
                          "Curso"
                        ]
                      }
                    },
                    {
                      "title": "Complete a frase",
                      "intent": "complete",
                      "data": {
                        "prompt": "Todo card pertence a uma ____.",
                        "placeholder": "microssequência"
                      }
                    },
                    {
                      "title": "Trecho de código",
                      "intent": "code",
                      "data": {
                        "language": "json",
                        "code": "{ \"contract\": \"aralearn.intent.v1\" }"
                      }
                    },
                    {
                      "title": "Tabela simples",
                      "intent": "table",
                      "data": {
                        "columns": [
                          "Campo",
                          "Obrigatório"
                        ],
                        "rows": [
                          ["contract", "sim"],
                          ["courses", "sim"]
                        ]
                      }
                    },
                    {
                      "title": "Fluxo básico",
                      "intent": "flow",
                      "data": {
                        "steps": [
                          "Ler",
                          "Validar",
                          "Compilar"
                        ]
                      }
                    },
                    {
                      "title": "Imagem provisória",
                      "intent": "image",
                      "data": {
                        "src": "public/example.png",
                        "alt": "Imagem de exemplo"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
